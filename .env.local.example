# ═══════════════════════════════════════════════════════════════
# PORTIX — Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# SETUP INSTRUCTIONS:
#   1. Copy this file:   cp .env.local.example .env.local
#   2. Fill in the values below from your Supabase project.
#   3. NEVER commit .env.local to git (it's in .gitignore).
#
# WHERE TO FIND THESE VALUES:
#   → Supabase Dashboard → Your Project → Settings → API
# ═══════════════════════════════════════════════════════════════


# ─── Supabase Project Config ─────────────────────────────────────────────────
# Required for all Supabase client connections (browser + server)

# Your Supabase project URL (e.g. https://xyzcompany.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Your Supabase anon/public key — safe to expose to the browser
# (RLS policies enforce security — this key alone cannot bypass them)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here


# ─── Supabase Service Role Key ────────────────────────────────────────────────
# DANGER: This key bypasses ALL Row Level Security policies.
# Use ONLY in secure server-side contexts (API routes, migration scripts).
# NEVER expose in client-side code or NEXT_PUBLIC_* variables.

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ─── Application Config ───────────────────────────────────────────────────────

# Application base URL (used for auth callback redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App name (used in email templates, window title, etc.)
NEXT_PUBLIC_APP_NAME=Portix


# ─── Optional: Supabase Local Dev ────────────────────────────────────────────
# Uncomment when running Supabase locally via `supabase start`

# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres


# ─── Notes ───────────────────────────────────────────────────────────────────
# Supabase Storage buckets to create manually in the dashboard:
#   • documents        (private)
#   • cargo-media      (private)
#   • swift-documents  (private)
#   • license-files    (private)
#   • avatars          (private)
#
# Migration files to run (in order) in Supabase SQL Editor:
#   supabase/migrations/00301_initial_schema.sql
#   supabase/migrations/00302_rls_policies.sql
#   supabase/migrations/00303_triggers.sql
#   supabase/migrations/00304_seed_data.sql   ← after creating auth users
